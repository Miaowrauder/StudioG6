  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "You can score points towards your current \nrun through damaging and killing
    Goblins \non the rink by either using attacks or by cutting \nthe ice underneath
    their feet!\n\n\n\nWhen you score points, a progress bar with a music note will
    appear, this is your score multiplier and the progress bar determines how long
    you have to add more score to it before it diminishes and the multiplier is set
    to 0.\n\nPro Tip: To reach higher scores, damaging/killing groups of goblins
    is best done in sustained, repeated succession to keep the score multiplier up,
    making your score unbeatable!"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
