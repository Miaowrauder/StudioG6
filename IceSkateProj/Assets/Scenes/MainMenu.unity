      m_Calls: []
  m_text: 'When skating along the ice - hold the left mouse button as you travel,
    to cut a trail in the ice.


    If the trail is looped back on then the ice
    will be cut!


    Cut a hole beneath the goblins to drop them into the icy water,
    but be careful - these holes are as dangerous to you as they are to the goblins,
    try not to fall in!

'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
